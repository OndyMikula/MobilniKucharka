<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MobilniKucharka.MainPage"
             Title="Dnešní menu"
             BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#121212}">

    <Grid RowDefinitions="Auto, *">

        <!-- HLAVIČKA S PŘEHLEDEM -->
        <Border Grid.Row="0" Margin="15,15,15,5" Padding="15" StrokeShape="RoundRectangle 10" Stroke="Transparent" BackgroundColor="#2196F3">
            <VerticalStackLayout Spacing="5">
                <Label Text="Tvoje nastavení:" TextColor="White" FontSize="14" FontAttributes="Bold" />
                <Label x:Name="SettingsSummaryLabel" TextColor="White" FontSize="14" />
                <Button Text="Změnit nastavení" Clicked="OnEditSettingsClicked" 
                        BackgroundColor="Transparent" TextColor="White" FontSize="12" 
                        HorizontalOptions="End" Padding="0" HeightRequest="30"/>
            </VerticalStackLayout>
        </Border>

        <!-- SEZNAM RECEPTŮ A CEN -->
        <CollectionView x:Name="RecipesCollectionView" Grid.Row="1">
            <CollectionView.ItemTemplate>
                <DataTemplate>

                    <Border Margin="0,0,0,15" Padding="0" StrokeShape="RoundRectangle 12" Stroke="LightGray" BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnRecipeTapped" CommandParameter="{Binding .}" />
                        </Border.GestureRecognizers>

                        <Grid ColumnDefinitions="120, *" RowDefinitions="Auto, *, Auto">
                            <Image Source="{Binding Recipe.ImageUrl}" Aspect="AspectFill" Grid.RowSpan="3" Grid.Column="0" />
                            <Label Text="{Binding Recipe.Name}" Grid.Column="1" Grid.Row="0" 
                                   FontAttributes="Bold" FontSize="18" Margin="10,10,10,0" LineBreakMode="TailTruncation" MaxLines="2" />
                            <Label Text="{Binding Recipe.PrepTime, StringFormat='Čas: {0} min'}" 
                                   Grid.Column="1" Grid.Row="1" FontSize="12" TextColor="Gray" Margin="10,5,10,0" />
                            <VerticalStackLayout Grid.Column="1" Grid.Row="2" Margin="10,10,10,10" Spacing="2">
                                <Label Text="{Binding CalculatedCost, StringFormat='Cena nákupu: {0} Kč'}" 
                                       TextColor="{Binding CostColor}" FontAttributes="Bold" FontSize="16" />
                                <Label Text="{Binding BudgetStatusText}" 
                                       TextColor="{Binding CostColor}" FontSize="12" />
                            </VerticalStackLayout>
                        </Grid>
                    </Border>

                </DataTemplate>
            </CollectionView.ItemTemplate>

            <CollectionView.EmptyView>
                <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="10">
                    <Label Text="🍲" FontSize="50" HorizontalOptions="Center" />
                    <Label Text="Žádné recepty nevyhovují tvému filtru." FontSize="16" FontAttributes="Bold" HorizontalOptions="Center" />
                    <Label Text="Zkus upravit diety nebo vybavení kuchyně." FontSize="14" TextColor="Gray" HorizontalOptions="Center" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>
        </CollectionView>
    </Grid>
</ContentPage>