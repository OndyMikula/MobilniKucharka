<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:services="clr-namespace:MobilniKucharka.Services"
             x:Class="MobilniKucharka.MainPage"
             Shell.NavBarIsVisible="False"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#121212}">

    <Grid RowDefinitions="Auto, *, Auto, Auto">

        <Grid Grid.Row="0" Padding="15,20,15,10" ColumnDefinitions="*, Auto">
            <Label Grid.Column="0" Text="Dnešní menu" 
                   TextColor="{AppThemeBinding Light=#000000, Dark=#FFFFFF}" 
                   FontSize="26" FontAttributes="Bold" VerticalOptions="Center" />
            <Button Grid.Column="1" Text="⚙️" BackgroundColor="Transparent" 
                    FontSize="24" Clicked="OnSettingsToolbarClicked" Padding="0" VerticalOptions="Center"/>
        </Grid>

        <Grid Grid.Row="1" RowDefinitions="Auto, Auto, Auto, *">
            <Border Grid.Row="0" Margin="15,5,15,5" Padding="12,8" StrokeShape="RoundRectangle 10" Stroke="Transparent" BackgroundColor="#2196F3">
                <Grid ColumnDefinitions="*, Auto" ColumnSpacing="10">
                    <VerticalStackLayout Grid.Column="0" Spacing="2" VerticalOptions="Center">
                        <Label Text="Tvoje nastavení:" TextColor="White" FontSize="12" FontAttributes="Bold" />
                        <Label x:Name="SettingsSummaryLabel" TextColor="White" FontSize="12" />
                    </VerticalStackLayout>
                    <Button Grid.Column="1" Text="Změnit" Clicked="OnEditSettingsClicked" 
                            BackgroundColor="#40FFFFFF" TextColor="White" FontSize="11" 
                            Padding="10,0" HeightRequest="32" CornerRadius="8" VerticalOptions="Center"/>
                </Grid>
            </Border>

            <Grid Grid.Row="1" ColumnDefinitions="*, Auto, Auto" Margin="15,0,15,5" ColumnSpacing="8">
                <Entry Grid.Column="0" x:Name="SearchEntry" 
                       Placeholder="Hledat recept podle názvu..." 
                       TextChanged="OnSearchTextChanged" 
                       Completed="OnSearchButtonClicked"
                       VerticalOptions="Center" />
                <Button Grid.Column="1" Text="🔍" FontSize="18" 
                        WidthRequest="44" HeightRequest="44" Padding="0" CornerRadius="22"
                        BackgroundColor="#2196F3" TextColor="White" Clicked="OnSearchButtonClicked" />
                <VerticalStackLayout Grid.Column="2" VerticalOptions="Center" HorizontalOptions="Center" Spacing="0">
                    <CheckBox x:Name="FilterByPreferencesCheckBox" 
                              CheckedChanged="OnFilterByPreferencesChanged" 
                              HorizontalOptions="Center" />
                    <Label Text="Dle preferencí" FontSize="9" TextColor="Gray" HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Grid>

            <Button Grid.Row="2" x:Name="ResetDatabaseButton" Text="🔄 Resetovat testovací databázi" Clicked="OnResetDatabaseClicked"
                    FontSize="11" TextColor="Gray" BackgroundColor="Transparent" 
                    HorizontalOptions="Center" Padding="0" HeightRequest="24" Margin="0,0,0,5"
                    IsVisible="False"/>

            <CollectionView x:Name="RecipesCollectionView" Grid.Row="3">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="services:RecipeWithCost">
                        <Border Margin="15,5,15,10" Padding="0" StrokeShape="RoundRectangle 12" Stroke="LightGray" BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnRecipeTapped" CommandParameter="{Binding .}" />
                            </Border.GestureRecognizers>
                            <Grid ColumnDefinitions="120, *" RowDefinitions="Auto, *, Auto">
                                <Image Source="{Binding Recipe.ImageUrl}" Aspect="AspectFill" Grid.RowSpan="3" Grid.Column="0" />
                                <Label Text="{Binding Recipe.Name}" Grid.Column="1" Grid.Row="0" 
                                       FontAttributes="Bold" FontSize="18" Margin="10,10,10,0" LineBreakMode="TailTruncation" MaxLines="2" />
                                <Label Text="{Binding Recipe.PrepTime, StringFormat='Čas: {0} min'}" 
                                       Grid.Column="1" Grid.Row="1" FontSize="12" TextColor="Gray" Margin="10,5,10,0" 
                                       IsVisible="{Binding Recipe.HasPrepTime}"/>
                                <VerticalStackLayout Grid.Column="1" Grid.Row="2" Margin="10,10,10,10" Spacing="2">
                                    <Label Text="{Binding CostDisplayText}" 
                                        TextColor="{Binding CostColor}" FontAttributes="Bold" FontSize="16" />
                                    <Label Text="{Binding BudgetStatusText}" 
                                           TextColor="{Binding CostColor}" FontSize="12" />
                                </VerticalStackLayout>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
                <CollectionView.EmptyView>
                    <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="10">
                        <Label Text="🍲" FontSize="50" HorizontalOptions="Center" />
                        <Label Text="Žádné recepty nevyhovují filtru." FontSize="16" FontAttributes="Bold" HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
            </CollectionView>
        </Grid>

        <Grid Grid.Row="2" ColumnDefinitions="0.5*, 0.5*" ColumnSpacing="15" Padding="15,10" BackgroundColor="Transparent">
            <Button Grid.Column="0" Text="Překvap mě!" Clicked="OnSearchRecipesClicked" 
                    BackgroundColor="#2196F3" TextColor="White" FontAttributes="Bold" FontSize="13" HeightRequest="50" CornerRadius="10"/>
            <Button Grid.Column="1" Text="Vytvořit recept" Clicked="OnCreateRecipeClicked" 
                    BackgroundColor="#4CAF50" TextColor="White" FontAttributes="Bold" HeightRequest="50" CornerRadius="10"/>
        </Grid>

        <Grid Grid.Row="3" ColumnDefinitions="*, *" Padding="10,10,10,20" BackgroundColor="{AppThemeBinding Light=#E0E0E0, Dark=#1F1F1F}">
            <Button Grid.Column="0" Text="Recepty" BackgroundColor="#2196F3" TextColor="White" FontAttributes="Bold" CornerRadius="10" Margin="5"/>
            <Button Grid.Column="1" Text="Záložky" Clicked="OnBookmarksClicked" BackgroundColor="Transparent" TextColor="{AppThemeBinding Light=Black, Dark=White}" FontAttributes="Bold" CornerRadius="10" Margin="5"/>
        </Grid>

    </Grid>
</ContentPage>