<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MobilniKucharka.OnboardingPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#121212}">

    <Grid RowDefinitions="Auto, *, Auto" Padding="20">

        <!-- HLAVIČKA -->
        <VerticalStackLayout Grid.Row="0" Spacing="10" Margin="0,10,0,20">
            <Label x:Name="StepTitle" FontSize="24" FontAttributes="Bold" HorizontalOptions="Center" TextColor="{AppThemeBinding Light=#111111, Dark=#FFFFFF}" />
            <Label x:Name="StepDescription" FontSize="14" TextColor="Gray" HorizontalOptions="Center" HorizontalTextAlignment="Center" />
            <ProgressBar x:Name="WizardProgress" Progress="0.25" ProgressColor="#4CAF50" HeightRequest="4" Margin="0,10,0,0"/>
        </VerticalStackLayout>

        <!-- KROK 1: Výběr obchodu -->
        <VerticalStackLayout x:Name="Step1_Shop" Grid.Row="1" Spacing="12" IsVisible="True" VerticalOptions="Center">
            <Button Text="Lidl" Clicked="OnShopSelected" CommandParameter="PriceLidl" BackgroundColor="#00509d" TextColor="White" HeightRequest="55" CornerRadius="8"/>
            <Button Text="Kaufland" Clicked="OnShopSelected" CommandParameter="PriceKaufland" BackgroundColor="#e10914" TextColor="White" HeightRequest="55" CornerRadius="8"/>
            <Button Text="Albert" Clicked="OnShopSelected" CommandParameter="PriceAlbert" BackgroundColor="#009639" TextColor="White" HeightRequest="55" CornerRadius="8"/>
            <Button Text="Tesco" Clicked="OnShopSelected" CommandParameter="PriceTesco" BackgroundColor="#00539f" TextColor="White" HeightRequest="55" CornerRadius="8"/>
            <Button Text="Billa" Clicked="OnShopSelected" CommandParameter="PriceBilla" BackgroundColor="#ffcc00" TextColor="Black" HeightRequest="55" CornerRadius="8"/>
            <Button Text="Penny" Clicked="OnShopSelected" CommandParameter="PricePenny" BackgroundColor="#d1021c" TextColor="White" HeightRequest="55" CornerRadius="8"/>

            <Label x:Name="SelectedShopLabel" Margin="0,15,0,0" FontSize="16" FontAttributes="Bold" HorizontalOptions="Center" TextColor="#4CAF50"/>
        </VerticalStackLayout>

        <!-- KROK 2: Lidé a Budget -->
        <VerticalStackLayout x:Name="Step2_Budget" Grid.Row="1" Spacing="20" IsVisible="False" VerticalOptions="Center">

            <Border Stroke="LightGray" StrokeShape="RoundRectangle 10" Padding="15" BackgroundColor="Transparent">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Pro kolik lidí bude nákup?" FontAttributes="Bold" FontSize="16"/>
                    <Stepper x:Name="PeopleStepper" Minimum="1" Maximum="10" Increment="1" Value="2" ValueChanged="OnPeopleChanged"/>
                    <Label x:Name="PeopleLabel" Text="2 lidé" FontSize="20" FontAttributes="Bold" HorizontalOptions="Center" TextColor="#2196F3"/>
                </VerticalStackLayout>
            </Border>

            <Border Stroke="LightGray" StrokeShape="RoundRectangle 10" Padding="15" BackgroundColor="Transparent">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Tvůj týdenní budget na suroviny:" FontAttributes="Bold" FontSize="16"/>
                    <Slider x:Name="BudgetSlider" Minimum="500" Maximum="10000" Value="2000" ValueChanged="OnBudgetChanged"/>
                    <Label x:Name="BudgetLabel" Text="2 000 Kč" FontSize="20" FontAttributes="Bold" HorizontalOptions="Center" TextColor="#4CAF50" />
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>

        <!-- KROK 3: Dietní potřeby -->
        <VerticalStackLayout x:Name="Step3_Diets" Grid.Row="1" Spacing="15" IsVisible="False" VerticalOptions="Center">
            <Label Text="Vyber své stravovací preference:" FontAttributes="Bold" FontSize="16" Margin="0,0,0,10"/>
            <HorizontalStackLayout Spacing="15">
                <CheckBox x:Name="CheckVegetarian" />
                <Label Text="Vegetarián" VerticalOptions="Center" FontSize="16"/>
            </HorizontalStackLayout>
            <HorizontalStackLayout Spacing="15">
                <CheckBox x:Name="CheckVegan" />
                <Label Text="Vegan" VerticalOptions="Center" FontSize="16"/>
            </HorizontalStackLayout>
            <HorizontalStackLayout Spacing="15">
                <CheckBox x:Name="CheckLactose" />
                <Label Text="Bezlaktózová dieta" VerticalOptions="Center" FontSize="16"/>
            </HorizontalStackLayout>
        </VerticalStackLayout>

        <!-- KROK 4: Spotřebiče -->
        <VerticalStackLayout x:Name="Step4_Appliances" Grid.Row="1" Spacing="15" IsVisible="False" VerticalOptions="Center">
            <Label Text="Jaké spotřebiče máš k dispozici?" FontAttributes="Bold" FontSize="16" Margin="0,0,0,10"/>
            <HorizontalStackLayout Spacing="15">
                <CheckBox x:Name="CheckOven" IsChecked="True"/>
                <Label Text="Trouba" VerticalOptions="Center" FontSize="16"/>
            </HorizontalStackLayout>
            <HorizontalStackLayout Spacing="15">
                <CheckBox x:Name="CheckStove" IsChecked="True"/>
                <Label Text="Sporák / Varná deska" VerticalOptions="Center" FontSize="16"/>
            </HorizontalStackLayout>
            <HorizontalStackLayout Spacing="15">
                <CheckBox x:Name="CheckKettle" IsChecked="True"/>
                <Label Text="Rychlovarná konvice" VerticalOptions="Center" FontSize="16"/>
            </HorizontalStackLayout>
            <HorizontalStackLayout Spacing="15">
                <CheckBox x:Name="CheckMicrowave" IsChecked="True"/>
                <Label Text="Mikrovlnná trouba" VerticalOptions="Center" FontSize="16"/>
            </HorizontalStackLayout>
        </VerticalStackLayout>

        <!-- SPODNÍ NAVIGACE -->
        <Grid Grid.Row="2" ColumnDefinitions="*, *" ColumnSpacing="15" Padding="0,15,0,10">
            <Button x:Name="BackButton" Text="Zpět" Clicked="OnBackClicked" IsVisible="False"
                    BackgroundColor="#9E9E9E" TextColor="White" CornerRadius="10" HeightRequest="50"/>

            <Button x:Name="NextButton" Grid.Column="1" Text="Pokračovat" Clicked="OnNextClicked" 
                    BackgroundColor="#2196F3" TextColor="White" CornerRadius="10" HeightRequest="50"/>
        </Grid>
    </Grid>
</ContentPage>