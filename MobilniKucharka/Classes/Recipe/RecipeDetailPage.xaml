<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MobilniKucharka.RecipeDetailPage"
             Title="Detail receptu"
             BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#121212}">

    <ScrollView>
        <VerticalStackLayout Spacing="0">

            <!-- 1. HERO OBRÁZEK RECEPTU -->
            <Grid HeightRequest="250">
                <Image x:Name="RecipeImage" Aspect="AspectFill" />

                <!-- Opravený gradient a VerticalOptions="End" -->
                <BoxView VerticalOptions="End" HeightRequest="80">
                    <BoxView.Background>
                        <LinearGradientBrush EndPoint="0,1">
                            <GradientStop Color="#00000000" Offset="0.0" />
                            <GradientStop Color="#CC000000" Offset="1.0" />
                        </LinearGradientBrush>
                    </BoxView.Background>
                </BoxView>

                <Label x:Name="RecipeNameLabel" VerticalOptions="End" Margin="20" 
                       FontSize="24" FontAttributes="Bold" TextColor="White" />
            </Grid>

            <VerticalStackLayout Padding="20" Spacing="25">

                <!-- 2. NUTRIČNÍ HODNOTY (Frame nahrazen za Border) -->
                <Grid ColumnDefinitions="*, *, *, *" ColumnSpacing="10">
                    <Border Grid.Column="0" Padding="5" HeightRequest="65" StrokeShape="RoundRectangle 8" Stroke="Transparent" BackgroundColor="#E3F2FD">
                        <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center">
                            <Label Text="Bílkoviny" FontSize="10" TextColor="#1565C0" HorizontalOptions="Center"/>
                            <Label x:Name="ProteinLabel" FontSize="15" FontAttributes="Bold" TextColor="#1565C0" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Column="1" Padding="5" HeightRequest="65" StrokeShape="RoundRectangle 8" Stroke="Transparent" BackgroundColor="#FFF3E0">
                        <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center">
                            <Label Text="Sacharidy" FontSize="10" TextColor="#EF6C00" HorizontalOptions="Center"/>
                            <Label x:Name="CarbsLabel" FontSize="15" FontAttributes="Bold" TextColor="#EF6C00" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Column="2" Padding="5" HeightRequest="65" StrokeShape="RoundRectangle 8" Stroke="Transparent" BackgroundColor="#E8F5E9">
                        <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center">
                            <Label Text="Tuky" FontSize="10" TextColor="#2E7D32" HorizontalOptions="Center"/>
                            <Label x:Name="FatLabel" FontSize="15" FontAttributes="Bold" TextColor="#2E7D32" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Column="3" Padding="5" HeightRequest="65" StrokeShape="RoundRectangle 8" Stroke="Transparent" BackgroundColor="#FFEBEE">
                        <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center">
                            <Label Text="Cukry" FontSize="10" TextColor="#C62828" HorizontalOptions="Center"/>
                            <Label x:Name="SugarLabel" FontSize="15" FontAttributes="Bold" TextColor="#C62828" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <!-- 3. NÁKUPNÍ SEZNAM -->
                <VerticalStackLayout Spacing="10">
                    <HorizontalStackLayout Spacing="10">
                        <Label Text="🛒" FontSize="20"/>
                        <Label Text="Nákupní seznam" FontSize="18" FontAttributes="Bold" VerticalOptions="Center" />
                        <Label x:Name="PeopleCountBadge" TextColor="Gray" FontSize="14" VerticalOptions="Center" Margin="5,0,0,0"/>
                    </HorizontalStackLayout>

                    <!-- Opravený BindableLayout správně vázaný na kontejner -->
                    <Border Padding="15" StrokeShape="RoundRectangle 10" Stroke="LightGray" BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}">
                        <VerticalStackLayout x:Name="IngredientsLayout">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnDefinitions="*, Auto, Auto" Padding="0,8">
                                        <Label Grid.Column="0" Text="{Binding Name}" VerticalOptions="Center" FontAttributes="Bold"/>
                                        <Label Grid.Column="1" Text="{Binding AmountText}" Margin="10,0" VerticalOptions="Center" TextColor="Gray"/>
                                        <Label Grid.Column="2" Text="{Binding CostText}" VerticalOptions="Center" TextColor="#4CAF50" FontAttributes="Bold"/>
                                    </Grid>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>
                    </Border>

                    <Label x:Name="TotalPriceLabel" FontSize="16" FontAttributes="Bold" HorizontalOptions="End" TextColor="#4CAF50" Margin="0,5,5,0"/>
                </VerticalStackLayout>

                <!-- 4. POSTUP PŘÍPRAVY -->
                <VerticalStackLayout Spacing="10">
                    <HorizontalStackLayout Spacing="10">
                        <Label Text="🍳" FontSize="20"/>
                        <Label Text="Postup přípravy" FontSize="18" FontAttributes="Bold" VerticalOptions="Center" />
                    </HorizontalStackLayout>

                    <Border Padding="15" StrokeShape="RoundRectangle 10" Stroke="LightGray" BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}">
                        <VerticalStackLayout x:Name="StepsLayout">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnDefinitions="Auto, *" Margin="0,8" VerticalOptions="Start">
                                        <Border Grid.Column="0" WidthRequest="26" HeightRequest="26" StrokeShape="RoundRectangle 13" BackgroundColor="#2196F3" Stroke="Transparent" VerticalOptions="Start" Margin="0,2,10,0">
                                            <Label Text="{Binding StepNumber}" TextColor="White" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center" FontSize="12"/>
                                        </Border>
                                        <Label Grid.Column="1" Text="{Binding StepText}" FontSize="15" LineHeight="1.2" VerticalOptions="Start"/>
                                    </Grid>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>